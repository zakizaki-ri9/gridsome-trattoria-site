---
import Layout from "../layouts/Layout.astro";
import MenuGallery from "../components/MenuGallery.astro";
---

<Layout title="Menu">
    <section class="menu-section">
        <div class="container">
            <h1>Menu</h1>
            <p class="description">
                当店のおすすめメニューです。画像をクリックして拡大表示できます。
            </p>

            <MenuGallery />
        </div>
    </section>
</Layout>

<style>
    .menu-section {
        padding: 60px 0;
    }
    h1 {
        color: var(--primary-color);
        text-align: center;
        margin-bottom: 10px;
        font-family: var(--font-family-heading);
    }
    .description {
        text-align: center;
        color: var(--text-muted);
        margin-bottom: 40px;
    }
</style>
