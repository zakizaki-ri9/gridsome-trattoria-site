---
import Layout from "../layouts/Layout.astro";
import MenuGallery from "../components/MenuGallery.astro";
---

<Layout title="Menu">
    <section class="menu-section">
        <div class="container">
            <h1>Menu</h1>
            <p class="description">
                当店のメニュー（一例）です。価格や内容は変動する場合がございます。<br>
                最新のメニューは食べログ、Instagram、または当店にてご確認ください。
            </p>

            <div class="external-links">
                <a href="https://tabelog.com/yamanashi/A1901/A190103/19011040/dtlmenu/photo/" target="_blank" rel="noopener noreferrer" class="btn-external btn-tabelog">
                    食べログの写真で確認する ↗︎
                </a>
                <a href="https://www.instagram.com/trattoriaporto" target="_blank" rel="noopener noreferrer" class="btn-external btn-instagram">
                    Instagramで確認する ↗︎
                </a>
            </div>

            <MenuGallery />
        </div>
    </section>
</Layout>

<style>
    .menu-section {
        padding: 60px 0;
    }
    h1 {
        color: var(--primary-color);
        text-align: center;
        margin-bottom: 10px;
        font-family: var(--font-family-heading);
    }
    .description {
        text-align: center;
        color: var(--text-muted);
        margin-bottom: 30px;
        line-height: 1.8;
    }
    .description small {
        font-size: 0.85em;
        color: #999;
    }
    .external-links {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }
    .btn-external {
        display: inline-block;
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: bold;
        text-decoration: none;
        transition: transform 0.2s, opacity 0.2s;
        font-size: 0.95rem;
    }
    .btn-external:hover {
        transform: translateY(-2px);
        opacity: 0.9;
    }
    .btn-tabelog {
        background-color: #d1752b; /* 食べログを意識したオレンジ色 */
        color: #fff;
    }
    .btn-instagram {
        background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
        color: #fff;
    }
</style>
